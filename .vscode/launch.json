{
   "version": "0.2.0",
   "configurations": [
      {
         "name": "E2 debugpy",
         "type": "debugpy",
         "request": "attach",
         "justMyCode": false,
         "connect": {
               "host": "localhost",
               "port": 5254
         },
         "pathMappings": [
               {
                  "localRoot": "${workspaceFolder}",
                  "remoteRoot": "${workspaceFolder}"
               }
         ]
      }
   ]
}
